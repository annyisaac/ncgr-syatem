# NCGR Ltd — environment configuration
#
# The app currently persists everything client-side in localStorage, so no
# environment variables are required to run it today. These placeholders are
# here for the planned migration to a real backend (Firebase / Postgres),
# where lib/db.ts becomes the single swap point.

# --- Example: Firebase (uncomment and fill in when wiring a real backend) ---
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=

# --- Example: Postgres / API backend ---
# DATABASE_URL=
# NEXTAUTH_SECRET=
