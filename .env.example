# NCGR Ltd — environment configuration
#
# The app stores all data in Supabase (Postgres). Copy this file to `.env`
# and fill in your project's values (Dashboard → Settings → API).
# The publishable key is safe for the browser.

NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
